{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlatformEngineerOutput",
  "type": "object",
  "oneOf": [
    {
      "description": "Skipped because no infrastructure changes are required",
      "required": ["skipped", "reason"],
      "additionalProperties": false,
      "properties": {
        "skipped": { "type": "boolean", "enum": [true] },
        "reason": { "type": "string" }
      }
    },
    {
      "description": "Full platform output when infrastructure changes are needed",
      "required": ["infra_files", "deployment", "observability", "rollout"],
      "additionalProperties": false,
      "properties": {
        "infra_files": {
          "type": "array",
          "description": "Infrastructure-as-code files (Dockerfile, k8s manifests, Terraform, etc.)",
          "items": {
            "type": "object",
            "required": ["path", "content"],
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "deployment": {
          "type": "object",
          "required": ["environment_variables", "secrets", "resource_limits", "health_check"],
          "additionalProperties": false,
          "properties": {
            "environment_variables": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "value_or_reference"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string" },
                  "value_or_reference": {
                    "type": "string",
                    "description": "Literal value or secret reference like {{ secrets.X }}"
                  }
                }
              }
            },
            "secrets": {
              "type": "array",
              "description": "Secret references — never plain text values",
              "items": {
                "type": "object",
                "required": ["name", "reference"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string" },
                  "reference": { "type": "string" }
                }
              }
            },
            "resource_limits": {
              "type": "object",
              "required": ["cpu", "memory"],
              "additionalProperties": false,
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            },
            "health_check": {
              "type": "object",
              "required": ["path", "interval_seconds", "timeout_seconds"],
              "additionalProperties": false,
              "properties": {
                "path": { "type": "string" },
                "interval_seconds": { "type": "integer" },
                "timeout_seconds": { "type": "integer" }
              }
            }
          }
        },
        "observability": {
          "type": "object",
          "required": ["metrics", "alerts"],
          "additionalProperties": false,
          "properties": {
            "metrics": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "type", "reason"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string" },
                  "type": {
                    "type": "string",
                    "enum": ["counter", "gauge", "histogram", "summary"]
                  },
                  "reason": { "type": "string" }
                }
              }
            },
            "alerts": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "condition", "reason"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string" },
                  "condition": { "type": "string" },
                  "reason": { "type": "string" }
                }
              }
            }
          }
        },
        "rollout": {
          "type": "object",
          "required": ["strategy", "rollback_steps", "migration_steps"],
          "additionalProperties": false,
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["rolling", "blue-green", "canary", "recreate"]
            },
            "rollback_steps": {
              "type": "array",
              "items": { "type": "string" }
            },
            "migration_steps": {
              "type": "array",
              "description": "DB migrations, config migrations, etc. Empty if none needed",
              "items": { "type": "string" }
            }
          }
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  ]
}
